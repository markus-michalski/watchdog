# Copy this file to .env.local and fill in your values.
# cp .env.example .env.local

APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me-to-a-random-string-32-chars

# SQLite — path relative to project root
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"

# Messenger: uses Doctrine transport (SQLite), no extra queue server needed
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

###> watchdog/auth ###
APP_ADMIN_USER=admin
# Generate hash with: php bin/console security:hash-password
APP_ADMIN_PASSWORD_HASH=
###< watchdog/auth ###

###> watchdog/url ###
# Base URL used in alert emails for links back to the app.
# Set to your actual domain in .env.local on the server.
# IMPORTANT: Use https:// in production — HTTP Basic Auth credentials are NOT encrypted over plain HTTP.
DEFAULT_URI=http://localhost:8087
###< watchdog/url ###

###> watchdog/proxy ###
# Set to your reverse proxy IP (e.g. 172.18.0.1) — NEVER use '*' in production (enables IP spoofing).
# Leave empty if Watchdog is directly internet-facing (no reverse proxy).
TRUSTED_PROXIES=
###< watchdog/proxy ###

###> watchdog/agent ###
# Register an agent via the dashboard UI (Agents → Register Agent) and paste the one-time token here.
# Leave empty to skip starting the agent container.
WATCHDOG_AGENT_TOKEN=
###< watchdog/agent ###

###> symfony/mailer ###
# Local dev (Mailpit via docker-compose): smtp://mailpit:1025
# Production: smtp://user:pass@smtp.example.com:587
MAILER_DSN=smtp://mailpit:1025
MAILER_FROM=watchdog@example.com
###< symfony/mailer ###
