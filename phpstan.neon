includes:
    - vendor/phpstan/phpstan-symfony/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 9
    paths:
        - src
    excludePaths:
        - src/Kernel.php
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
    ignoreErrors:
        # Doctrine assigns $id via reflection — PHPStan cannot see this
        - message: '#Property App\\Entity\\.*::.*id.*is never assigned int so it can be removed from the property type#'
          path: src/Entity
