{% extends 'base.html.twig' %}

{% block title %}{{ title }} — Watchdog{% endblock %}

{% block body %}
<div class="max-w-md">
    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('contact_index') }}" class="text-gray-500 hover:text-gray-700 text-sm">← Contacts</a>
        <h1 class="text-2xl font-bold text-gray-800">{{ title }}</h1>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        {% if error %}
            <div class="mb-4 px-4 py-3 rounded bg-red-100 text-red-800 border border-red-200 text-sm">{{ error }}</div>
        {% endif %}

        <form method="post" class="space-y-4">
            <input type="hidden" name="_token" value="{{ csrf_token('contact_form') }}">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="contact_name">Name</label>
                <input type="text" id="contact_name" name="name" required
                       value="{{ contact ? contact.name : '' }}"
                       class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1" for="contact_email">Email</label>
                <input type="email" id="contact_email" name="email" required
                       value="{{ contact ? contact.email : '' }}"
                       class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="flex gap-3 pt-2">
                <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded hover:bg-blue-700 text-sm font-medium">
                    Save
                </button>
                <a href="{{ path('contact_index') }}" class="text-gray-600 hover:text-gray-800 px-3 py-2 text-sm">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
