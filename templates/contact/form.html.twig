{% extends 'base.html.twig' %}

{% block title %}Add Contact — Watchdog{% endblock %}

{% block body %}
<div class="max-w-md">
    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('site_show', {id: site.id}) }}" class="text-gray-500 hover:text-gray-700 text-sm">← {{ site.name }}</a>
        <h1 class="text-2xl font-bold text-gray-800">Add Contact</h1>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <form method="post" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input type="text" name="name" required
                    class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" name="email" required
                    class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div class="flex gap-3 pt-2">
                <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded hover:bg-blue-700 text-sm font-medium">
                    Add Contact
                </button>
                <a href="{{ path('site_show', {id: site.id}) }}" class="text-gray-600 hover:text-gray-800 px-3 py-2 text-sm">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
