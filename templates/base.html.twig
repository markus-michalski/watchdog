<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Watchdog{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        {{ importmap('app') }}
    </head>
    <body class="bg-gray-100 min-h-screen">

        <nav class="bg-gray-900 text-white shadow">
            <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
                <a href="{{ path('dashboard') }}" class="flex items-center">
                    <img src="{{ asset('images/logo_watch_dog_white.png') }}" alt="Watchdog" width="32" height="32" decoding="async" class="h-8 w-auto">
                </a>
                <div class="flex gap-6 text-sm">
                    <a href="{{ path('dashboard') }}" class="hover:text-gray-300">Dashboard</a>
                    <a href="{{ path('site_index') }}" class="hover:text-gray-300">Sites</a>
                    <a href="{{ path('contact_index') }}" class="hover:text-gray-300">Contacts</a>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto px-4 py-8">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-4 px-4 py-3 rounded {% if type == 'success' %}bg-green-100 text-green-800 border border-green-200{% elseif type == 'error' %}bg-red-100 text-red-800 border border-red-200{% else %}bg-blue-100 text-blue-800 border border-blue-200{% endif %}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
