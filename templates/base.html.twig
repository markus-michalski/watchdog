<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="icon" type="image/png" href="{{ asset('favicon/favicon-96x96.png') }}" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="{{ asset('favicon/favicon.svg') }}" />
        <link rel="shortcut icon" href="{{ asset('favicon/favicon.ico') }}" />
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('favicon/apple-touch-icon.png') }}" />
        <meta name="apple-mobile-web-app-title" content="Watchdog" />
        <link rel="manifest" href="{{ asset('favicon/site.webmanifest') }}" />
        <title>{% block title %}Watchdog{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        {{ importmap('app') }}
    </head>
    <body class="bg-gray-100 min-h-screen flex flex-col">

        <nav class="bg-gray-900 text-white shadow sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
                <a href="{{ path('dashboard') }}" class="flex items-center">
                    <img src="{{ asset('images/logo_watch_dog_white.png') }}" alt="Watchdog" width="64" height="64" decoding="async" class="h-16 w-auto">
                </a>
                <div class="flex gap-6 text-sm">
                    <a href="{{ path('dashboard') }}" class="hover:text-gray-300">Dashboard</a>
                    <a href="{{ path('client_index') }}" class="hover:text-gray-300">Clients</a>
                    <a href="{{ path('contact_index') }}" class="hover:text-gray-300">Contacts</a>
                    <a href="{{ path('agent_index') }}" class="hover:text-gray-300">Agents</a>
                </div>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto px-4 py-8 flex-1 w-full">
            {% for message in app.flashes('success') %}
                <div class="mb-4 px-4 py-3 rounded bg-green-100 text-green-800 border border-green-200">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="mb-4 px-4 py-3 rounded bg-red-100 text-red-800 border border-red-200">{{ message }}</div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="bg-gray-900 text-gray-400 text-sm py-4">
            <div class="max-w-7xl mx-auto px-4 flex gap-6 justify-center">
                <a href="{{ path('legal_impressum') }}" class="hover:text-white">Impressum</a>
                <a href="{{ path('legal_datenschutz') }}" class="hover:text-white">Datenschutz</a>
            </div>
        </footer>

        <div id="delete-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4"
             role="dialog" aria-modal="true" aria-labelledby="delete-modal-title">
            <div class="absolute inset-0 bg-black/40" id="delete-modal-backdrop"></div>
            <div class="relative bg-white rounded-xl shadow-2xl p-6 max-w-sm w-full">
                <div class="flex items-start gap-4 mb-5">
                    <div class="flex-shrink-0 w-10 h-10 rounded-full bg-red-100 flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                        </svg>
                    </div>
                    <div>
                        <h3 id="delete-modal-title" class="font-semibold text-gray-900 text-sm">Confirm deletion</h3>
                        <p id="delete-modal-message" class="text-sm text-gray-500 mt-1"></p>
                    </div>
                </div>
                <div class="flex justify-end gap-2">
                    <button id="delete-modal-cancel" type="button"
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer">
                        Cancel
                    </button>
                    <button id="delete-modal-confirm" type="button"
                            class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 cursor-pointer">
                        Delete
                    </button>
                </div>
            </div>
        </div>

        <script>
        (function () {
            const modal      = document.getElementById('delete-modal');
            const msgEl      = document.getElementById('delete-modal-message');
            const backdrop   = document.getElementById('delete-modal-backdrop');
            const cancelBtn  = document.getElementById('delete-modal-cancel');
            const confirmBtn = document.getElementById('delete-modal-confirm');
            let pendingForm  = null;
            let triggerEl    = null;

            function open(form, msg) {
                pendingForm = form;
                triggerEl   = document.activeElement;
                msgEl.textContent = msg;
                confirmBtn.disabled = false;
                modal.classList.remove('hidden');
                confirmBtn.focus();
            }

            function close() {
                modal.classList.add('hidden');
                pendingForm = null;
                if (triggerEl) { triggerEl.focus(); triggerEl = null; }
            }

            cancelBtn.addEventListener('click', close);
            backdrop.addEventListener('click', close);
            document.addEventListener('keydown', e => {
                if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
            });

            confirmBtn.addEventListener('click', () => {
                if (!pendingForm) return;
                confirmBtn.disabled = true;
                pendingForm.submit();
            });

            document.addEventListener('submit', e => {
                const msg = e.target.dataset.confirmMessage;
                if (!msg) return;
                e.preventDefault();
                open(e.target, msg);
            });
        }());
        </script>
    </body>
</html>
