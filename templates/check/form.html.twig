{% extends 'base.html.twig' %}

{% block title %}{{ title }} — Watchdog{% endblock %}

{% block body %}
<div class="max-w-lg">
    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('client_show', {id: client.id}) }}" class="text-gray-500 hover:text-gray-700 text-sm">← {{ client.name }}</a>
        <h1 class="text-2xl font-bold text-gray-800">{{ title }}</h1>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}

        <div>
            {{ form_label(form.type, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.type, {attr: {class: 'w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.type) }}
        </div>

        <div>
            {{ form_label(form.runner, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.runner, {attr: {class: 'w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.runner) }}
            <p class="text-xs text-gray-400 mt-0.5">Dashboard = blackbox checks from the server. Agent = local checks on the monitored machine.</p>
        </div>

        <div id="agent-field-wrapper" class="hidden">
            {{ form_label(form.agent, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.agent, {attr: {class: 'w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.agent) }}
        </div>

        <div id="interval-field">
            {{ form_label(form.checkIntervalMinutes, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            <div class="flex items-center gap-2">
                {{ form_widget(form.checkIntervalMinutes.days,     {attr: {class: 'border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-16 text-center'}}) }}
                <span class="text-sm text-gray-500">d</span>
                {{ form_widget(form.checkIntervalMinutes.hours,    {attr: {class: 'border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-16 text-center'}}) }}
                <span class="text-sm text-gray-500">h</span>
                {{ form_widget(form.checkIntervalMinutes.minutes,  {attr: {class: 'border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-16 text-center'}}) }}
                <span class="text-sm text-gray-500">min</span>
            </div>
            {{ form_errors(form.checkIntervalMinutes) }}
            {%- do form.checkIntervalMinutes.setRendered() -%}
        </div>

        <div>
            {{ form_label(form.runAtTime, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            <div class="flex items-center gap-2">
                <input type="time"
                       id="{{ form.runAtTime.vars.id }}"
                       name="{{ form.runAtTime.vars.full_name }}"
                       value="{{ form.runAtTime.vars.value }}"
                       class="border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-36">
                <button type="button" id="run-at-time-clear"
                        class="text-gray-400 hover:text-gray-600 text-lg leading-none hidden"
                        title="Clear — switch back to interval">×</button>
            </div>
            {%- do form.runAtTime.setRendered() -%}
            <p class="text-xs text-gray-400 mt-0.5">If set, the check runs once daily at this time. The interval above is ignored.</p>
            {{ form_errors(form.runAtTime) }}
        </div>

        {# Dynamic config fields — rendered per check type #}
        <div id="config-fields">
            {% for type, fields in schemas %}
                <div class="config-section space-y-3" data-type="{{ type }}" style="display: none;" aria-hidden="true">
                    {% if fields is empty %}
                        <p class="text-sm text-gray-400 italic">
                            No additional configuration needed.
                        </p>
                    {% else %}
                        {% for field in fields %}
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">
                                    {{ field.label }}
                                    {% if field.required %}<span class="text-red-500">*</span>{% endif %}
                                </label>
                                {% if field.type == 'client_url_select' %}
                                    {% if clientUrls is empty %}
                                        <p class="text-sm text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-2">
                                            No URLs configured for this client yet.
                                            <a href="{{ path('client_url_new', {id: client.id}) }}" class="underline font-medium">Add a URL first.</a>
                                        </p>
                                        <input type="hidden" name="check_config_{{ field.name }}" value="">
                                    {% else %}
                                        <select name="check_config_{{ field.name }}"
                                                id="check_config_{{ type }}_{{ field.name }}"
                                                class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                                                {% if field.required %}data-required="1"{% endif %}>
                                            <option value="">— Select URL —</option>
                                            {% for clientUrl in clientUrls|sort((a, b) => (a.label ?? a.url) <=> (b.label ?? b.url)) %}
                                                <option value="{{ clientUrl.id }}"
                                                        {% if check.config.client_url_id is defined and check.config.client_url_id == clientUrl.id %}selected{% endif %}>
                                                    {{ clientUrl.displayLabel }}{% if clientUrl.hasBasicAuth() %} [BasicAuth]{% endif %}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    {% endif %}
                                {% elseif field.type == 'client_url_multiselect' %}
                                    {% if clientUrls is empty %}
                                        <p class="text-sm text-amber-600 bg-amber-50 border border-amber-200 rounded px-3 py-2">
                                            No URLs configured for this client yet.
                                            <a href="{{ path('client_url_new', {id: client.id}) }}" class="underline font-medium">Add a URL first.</a>
                                        </p>
                                    {% else %}
                                        {%- set selectedHosts = check.config[field.name] ?? [] -%}
                                        <div class="space-y-1.5 border border-gray-200 rounded px-3 py-2.5">
                                            {% for clientUrl in clientUrls|sort((a, b) => (a.label ?? a.url) <=> (b.label ?? b.url)) %}
                                                <label class="flex items-center gap-2 text-sm text-gray-700 cursor-pointer select-none">
                                                    <input type="checkbox"
                                                           name="check_config_{{ field.name }}[]"
                                                           value="{{ clientUrl.hostname }}"
                                                           class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                                           {% if clientUrl.hostname in selectedHosts %}checked{% endif %}>
                                                    <span>{{ clientUrl.displayLabel }}</span>
                                                    {% if clientUrl.hostname != clientUrl.displayLabel %}
                                                        <span class="text-gray-400 text-xs">({{ clientUrl.hostname }})</span>
                                                    {% endif %}
                                                </label>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                {% elseif field.type == 'duration' %}
                                    {%- set _dval = check.config[field.name] is defined ? check.config[field.name]|default(field.default) : field.default -%}
                                    <div class="flex items-center gap-2" data-duration-field>
                                        <input type="hidden"
                                               name="check_config_{{ field.name }}"
                                               class="duration-hidden"
                                               value="{{ _dval }}">
                                        <input type="number" min="0" placeholder="0"
                                               class="duration-days border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-16 text-center">
                                        <span class="text-sm text-gray-500">d</span>
                                        <input type="number" min="0" max="23" placeholder="0"
                                               class="duration-hours border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-16 text-center">
                                        <span class="text-sm text-gray-500">h</span>
                                        <input type="number" min="0" max="59" placeholder="0"
                                               class="duration-mins border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-16 text-center">
                                        <span class="text-sm text-gray-500">min</span>
                                    </div>
                                {% else %}
                                    <input
                                        type="{{ field.type }}"
                                        name="check_config_{{ field.name }}"
                                        id="check_config_{{ type }}_{{ field.name }}"
                                        class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                                        placeholder="{{ field.placeholder }}"
                                        {% if field.required %}data-required="1"{% endif %}
                                        value="{{ check.config[field.name] is defined
                                            ? (field.name == 'expected_status_codes' and check.config[field.name] is iterable
                                                ? check.config[field.name]|join(',')
                                                : check.config[field.name])
                                            : field.default }}"
                                    >
                                {% endif %}
                                {% if field.help %}
                                    <p class="text-xs text-gray-400 mt-0.5">{{ field.help }}</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            {% endfor %}
        </div>

        <div>
            {{ form_label(form.retentionDays, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            <div class="flex items-center gap-2">
                {{ form_widget(form.retentionDays, {attr: {class: 'border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 w-24'}}) }}
                <span class="text-sm text-gray-500">days</span>
            </div>
            <p class="text-xs text-gray-400 mt-0.5">Leave empty to keep forever. Example: 1 for http checks every 5 min, 28 for daily checks.</p>
            {{ form_errors(form.retentionDays) }}
        </div>

        <div class="flex items-center gap-2">
            {{ form_widget(form.isActive) }}
            {{ form_label(form.isActive, null, {label_attr: {class: 'text-sm text-gray-700'}}) }}
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded hover:bg-blue-700 text-sm font-medium">
                Save
            </button>
            <a href="{{ path('client_show', {id: client.id}) }}" class="text-gray-600 hover:text-gray-800 px-3 py-2 text-sm">
                Cancel
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>

<script>
(function () {
    function showConfigForType(type) {
        document.querySelectorAll('.config-section').forEach(el => {
            const visible = el.dataset.type === type;
            el.style.display = visible ? '' : 'none';
            el.setAttribute('aria-hidden', visible ? 'false' : 'true');
            el.querySelectorAll('input[data-required]').forEach(input => {
                input.required = visible;
            });
        });
    }

    const typeSelect = document.querySelector('[data-check-type]');
    if (typeSelect) {
        showConfigForType(typeSelect.value);
        typeSelect.addEventListener('change', () => {
            showConfigForType(typeSelect.value);
            if (timeInput) { timeInput.value = ''; syncIntervalState(); }
        });
    }

    // Show/hide agent dropdown based on runner selection
    const runnerSelect = document.querySelector('[data-runner-select]');
    const agentWrapper = document.getElementById('agent-field-wrapper');
    function syncAgentField() {
        if (!runnerSelect || !agentWrapper) return;
        const isAgent = runnerSelect.value === 'agent';
        agentWrapper.classList.toggle('hidden', !isAgent);
        const agentSelect = agentWrapper.querySelector('select');
        if (agentSelect) agentSelect.required = isAgent;
    }
    if (runnerSelect) {
        syncAgentField();
        runnerSelect.addEventListener('change', syncAgentField);
    }

    // Disable inputs in hidden sections so duplicate field names don't overwrite submitted values
    const formEl = document.querySelector('form');
    if (formEl) {
        formEl.addEventListener('submit', () => {
            document.querySelectorAll('.config-section[aria-hidden="true"] input, .config-section[aria-hidden="true"] select').forEach(el => {
                el.disabled = true;
            });
        });
    }

    const timeInput     = document.getElementById('{{ form.runAtTime.vars.id }}');
    const intervalField = document.getElementById('interval-field');
    const intervalInputs = intervalField ? [...intervalField.querySelectorAll('input[type="number"]')] : [];

    const clearBtn = document.getElementById('run-at-time-clear');

    function syncIntervalState() {
        const hasTime = timeInput && timeInput.value.trim() !== '';
        if (!intervalField) return;
        intervalField.style.opacity = hasTime ? '0.4' : '';
        intervalField.style.pointerEvents = hasTime ? 'none' : '';
        intervalInputs.forEach(i => { i.readOnly = hasTime; });
        if (clearBtn) clearBtn.classList.toggle('hidden', !hasTime);
    }

    // Initialize d/h/min display from the hidden minutes value for duration config fields
    document.querySelectorAll('[data-duration-field]').forEach(container => {
        const hidden = container.querySelector('.duration-hidden');
        if (!hidden) return;

        const total = parseInt(hidden.value, 10) || 0;
        const daysInput  = container.querySelector('.duration-days');
        const hoursInput = container.querySelector('.duration-hours');
        const minsInput  = container.querySelector('.duration-mins');

        daysInput.value  = Math.floor(total / 1440);
        hoursInput.value = Math.floor((total % 1440) / 60);
        minsInput.value  = total % 60;

        function syncHidden() {
            hidden.value = (parseInt(daysInput.value,  10) || 0) * 1440
                         + (parseInt(hoursInput.value, 10) || 0) * 60
                         + (parseInt(minsInput.value,  10) || 0);
        }

        [daysInput, hoursInput, minsInput].forEach(inp => inp.addEventListener('input', syncHidden));
    });

    if (timeInput) {
        timeInput.addEventListener('input', syncIntervalState);
        timeInput.addEventListener('change', syncIntervalState);
        syncIntervalState();
    }

    if (clearBtn) {
        clearBtn.addEventListener('click', () => {
            timeInput.value = '';
            syncIntervalState();
        });
    }
}());
</script>
{% endblock %}
