{% extends 'base.html.twig' %}

{% block title %}Dashboard — Watchdog{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Dashboard</h1>
    <a href="{{ path('site_new') }}" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm">
        + Add Site
    </a>
</div>

{% if sites is empty %}
    <div class="bg-white rounded-lg shadow p-8 text-center text-gray-500">
        <p class="text-lg mb-2">No sites configured yet.</p>
        <a href="{{ path('site_new') }}" class="text-blue-600 hover:underline">Add your first site</a>
    </div>
{% else %}
    <div class="grid gap-4">
        {% for site in sites %}
            <div class="bg-white rounded-lg shadow p-6">
                <div class="flex items-start justify-between mb-4">
                    <div>
                        <h2 class="text-lg font-semibold text-gray-800">
                            <a href="{{ path('site_show', {id: site.id}) }}" class="hover:text-blue-600">
                                {{ site.name }}
                            </a>
                        </h2>
                        <p class="text-sm text-gray-500">
                            <a href="{{ site.url }}" target="_blank" rel="noopener" class="hover:underline">{{ site.url }}</a>
                            {% if site.hasBasicAuth() %}
                                <span class="ml-2 text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded">BasicAuth</span>
                            {% endif %}
                        </p>
                    </div>
                    <span class="text-xs {% if site.isActive %}text-green-600{% else %}text-gray-400{% endif %}">
                        {{ site.isActive ? 'Active' : 'Inactive' }}
                    </span>
                </div>

                {% if site.checks is empty %}
                    <p class="text-sm text-gray-400 italic">No checks defined.
                        <a href="{{ path('check_new', {siteId: site.id}) }}" class="text-blue-600 hover:underline">Add check</a>
                    </p>
                {% else %}
                    <div class="flex flex-wrap gap-3">
                        {% for check in site.checks %}
                            {% set result = latestResults[check.id] ?? null %}
                            <div class="flex items-center gap-2 text-sm border rounded px-3 py-2 bg-gray-50">
                                <span class="font-medium text-gray-700">{{ check.label }}</span>
                                {% if result %}
                                    <span class="px-2 py-0.5 rounded text-xs font-semibold {{ result.status.cssClass() }}">
                                        {{ result.status.label() }}
                                    </span>
                                    <span class="text-xs text-gray-400">{{ result.checkedAt|date('H:i') }}</span>
                                    {% if result.responseTimeMs %}
                                        <span class="text-xs text-gray-400">{{ result.responseTimeMs }}ms</span>
                                    {% endif %}
                                {% else %}
                                    <span class="px-2 py-0.5 rounded text-xs font-semibold text-gray-500 bg-gray-100">PENDING</span>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
