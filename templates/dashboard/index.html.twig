{% extends 'base.html.twig' %}

{% block title %}Dashboard — Watchdog{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-bold text-gray-800">Dashboard</h1>
    <a href="{{ path('site_new') }}" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm">
        + Add Site
    </a>
</div>

{% if sites is empty %}
    <div class="bg-white rounded-lg shadow p-8 text-center text-gray-500">
        <p class="text-lg mb-2">No sites configured yet.</p>
        <a href="{{ path('site_new') }}" class="text-blue-600 hover:underline">Add your first site</a>
    </div>
{% else %}
    {# Filter bar #}
    <div class="flex flex-wrap items-center gap-3 mb-4">
        <input type="search" id="dashboard-search" placeholder="Filter by name…"
               class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 w-52">
        <div class="flex gap-1.5" id="status-filters">
            <button data-status-filter="all"   class="filter-btn active px-3 py-1.5 rounded text-xs font-medium border border-gray-300 bg-gray-100 text-gray-700">All</button>
            <button data-status-filter="ok"    class="filter-btn px-3 py-1.5 rounded text-xs font-medium border border-green-200 text-green-700 hover:bg-green-50">OK</button>
            <button data-status-filter="warn"  class="filter-btn px-3 py-1.5 rounded text-xs font-medium border border-orange-200 text-orange-700 hover:bg-orange-50">WARN</button>
            <button data-status-filter="fail"  class="filter-btn px-3 py-1.5 rounded text-xs font-medium border border-red-200 text-red-700 hover:bg-red-50">FAIL</button>
            <button data-status-filter="unknown" class="filter-btn px-3 py-1.5 rounded text-xs font-medium border border-yellow-200 text-yellow-700 hover:bg-yellow-50">UNKNOWN</button>
            <button data-status-filter="pending" class="filter-btn px-3 py-1.5 rounded text-xs font-medium border border-gray-200 text-gray-500 hover:bg-gray-50">PENDING</button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="dashboard-grid">
        {% for site in sites %}
            {% set siteStatus = siteStatuses[site.id] %}
            {% if siteStatus is null %}
                {% set borderClass = 'border-l-4 border-gray-300' %}
                {% set badgeClass = 'bg-gray-100 text-gray-500' %}
                {% set badgeLabel = 'PENDING' %}
                {% set statusKey = 'pending' %}
            {% elseif siteStatus.value == 'ok' %}
                {% set borderClass = siteStatus.cardBorderClass() %}
                {% set badgeClass = 'bg-green-100 text-green-700' %}
                {% set badgeLabel = 'OK' %}
                {% set statusKey = 'ok' %}
            {% elseif siteStatus.value == 'warn' %}
                {% set borderClass = siteStatus.cardBorderClass() %}
                {% set badgeClass = 'bg-orange-100 text-orange-700' %}
                {% set badgeLabel = 'WARN' %}
                {% set statusKey = 'warn' %}
            {% elseif siteStatus.value == 'fail' %}
                {% set borderClass = siteStatus.cardBorderClass() %}
                {% set badgeClass = 'bg-red-100 text-red-700' %}
                {% set badgeLabel = 'FAIL' %}
                {% set statusKey = 'fail' %}
            {% else %}
                {% set borderClass = siteStatus.cardBorderClass() %}
                {% set badgeClass = 'bg-yellow-100 text-yellow-700' %}
                {% set badgeLabel = 'UNKNOWN' %}
                {% set statusKey = 'unknown' %}
            {% endif %}

            <div class="bg-white rounded-lg shadow {{ borderClass }} overflow-hidden"
                 data-site-card
                 data-name="{{ site.name|lower }}"
                 data-status="{{ statusKey }}">
                <div class="p-5">
                    {# Card header: site name + aggregate status + actions #}
                    <div class="flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <a href="{{ path('site_show', {id: site.id}) }}" class="text-lg font-semibold text-gray-800 hover:text-blue-600">
                                {{ site.name }}
                            </a>
                            <p class="text-sm text-gray-500 mt-0.5">
                                <a href="{{ site.url }}" target="_blank" rel="noopener" class="hover:underline">{{ site.url }}</a>
                                {% if site.hasBasicAuth() %}
                                    <span class="ml-2 text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded">BasicAuth</span>
                                {% endif %}
                                {% if not site.isActive %}
                                    <span class="ml-2 text-xs bg-gray-100 text-gray-400 px-2 py-0.5 rounded">Inactive</span>
                                {% endif %}
                            </p>
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            <span class="text-sm font-bold px-3 py-1.5 rounded-full {{ badgeClass }}">
                                {{ badgeLabel }}
                            </span>
                            <a href="{{ path('site_edit', {id: site.id}) }}"
                               class="border border-blue-300 text-blue-700 px-2.5 py-1 rounded text-xs hover:bg-blue-50">
                                Edit
                            </a>
                            <form action="{{ path('site_delete', {id: site.id}) }}" method="post" class="inline"
                                  onsubmit="return confirm('Delete site {{ site.name|e('js') }} and all its checks?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_site' ~ site.id) }}">
                                <button type="submit"
                                        class="border border-red-300 text-red-700 px-2.5 py-1 rounded text-xs hover:bg-red-50 cursor-pointer">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>

                    {# Check rows #}
                    {% if site.checks is empty %}
                        <p class="text-sm text-gray-400 italic mt-4">
                            No checks defined.
                            <a href="{{ path('check_new', {siteId: site.id}) }}" class="text-blue-600 hover:underline">Add check</a>
                        </p>
                    {% else %}
                        <div class="mt-4 space-y-2 border-t border-gray-100 pt-3">
                            {% for check in site.checks|sort((a, b) => a.label <=> b.label) %}
                                {% set result = latestResults[check.id] ?? null %}
                                <div class="flex items-center gap-3 text-sm">
                                    {% if result %}
                                        <span class="w-2.5 h-2.5 rounded-full shrink-0 {{ result.status.dotClass() }}"></span>
                                    {% else %}
                                        <span class="w-2.5 h-2.5 rounded-full shrink-0 bg-gray-300"></span>
                                    {% endif %}

                                    <a href="{{ path('check_history', {siteId: site.id, checkId: check.id}) }}"
                                       class="flex-1 text-gray-700 hover:text-blue-600 truncate">
                                        {{ check.label }}
                                    </a>

                                    {% if result %}
                                        <span class="w-16 text-center rounded text-xs font-bold py-0.5 {{ result.status.cssClass() }} shrink-0">
                                            {{ result.status.label() }}
                                        </span>
                                        <span class="text-xs text-gray-400 w-10 text-right shrink-0">
                                            {{ result.checkedAt|date('H:i') }}
                                        </span>
                                        <span class="text-xs text-gray-400 w-14 text-right shrink-0 hidden sm:block">
                                            {{ result.responseTimeMs ? result.responseTimeMs ~ 'ms' : '' }}
                                        </span>
                                    {% else %}
                                        <span class="w-16 text-center rounded text-xs font-bold py-0.5 text-gray-400 bg-gray-100 shrink-0">PENDING</span>
                                        <span class="w-10 hidden sm:block"></span>
                                        <span class="w-14 hidden sm:block"></span>
                                    {% endif %}

                                    {% if not check.isActive %}
                                        <span class="text-xs text-gray-400 shrink-0">off</span>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

    <p id="dashboard-empty" class="hidden text-center text-gray-400 text-sm mt-8">No sites match your filter.</p>
{% endif %}

<script>
(function () {
    const cards = document.querySelectorAll('[data-site-card]');
    const search = document.getElementById('dashboard-search');
    const btns = document.querySelectorAll('[data-status-filter]');
    const empty = document.getElementById('dashboard-empty');
    let activeStatus = 'all';

    function applyFilters() {
        const q = search ? search.value.toLowerCase().trim() : '';
        let visible = 0;
        cards.forEach(card => {
            const nameMatch = !q || card.dataset.name.includes(q);
            const statusMatch = activeStatus === 'all' || card.dataset.status === activeStatus;
            const show = nameMatch && statusMatch;
            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        if (empty) empty.classList.toggle('hidden', visible > 0);
    }

    if (search) {
        search.addEventListener('input', applyFilters);
    }

    btns.forEach(btn => {
        btn.addEventListener('click', () => {
            activeStatus = btn.dataset.statusFilter;
            btns.forEach(b => b.classList.remove('active', 'ring-2', 'ring-offset-1',
                'ring-gray-400', 'ring-green-400', 'ring-orange-400', 'ring-red-400',
                'ring-yellow-400', 'bg-gray-100', 'bg-green-100', 'bg-orange-100',
                'bg-red-100', 'bg-yellow-100'));
            btn.classList.add('active');
            switch (activeStatus) {
                case 'ok':      btn.classList.add('bg-green-100'); break;
                case 'warn':    btn.classList.add('bg-orange-100'); break;
                case 'fail':    btn.classList.add('bg-red-100'); break;
                case 'unknown': btn.classList.add('bg-yellow-100'); break;
                default:        btn.classList.add('bg-gray-100'); break;
            }
            applyFilters();
        });
    });
})();
</script>
{% endblock %}
