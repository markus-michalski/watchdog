{% extends 'base.html.twig' %}

{% block title %}{{ title }} — Watchdog{% endblock %}

{% block body %}
<div class="max-w-lg">
    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('agent_index') }}" class="text-gray-500 hover:text-gray-700 text-sm">← Agents</a>
        <h1 class="text-2xl font-bold text-gray-800">{{ title }}</h1>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}

        <div>
            {{ form_label(form.name, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
            {{ form_widget(form.name, {attr: {class: 'w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.name) }}
            <p class="text-xs text-gray-400 mt-0.5">A unique, descriptive name for this agent (e.g. prod-server-01, staging-node).</p>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded hover:bg-blue-700 text-sm font-medium">
                Save
            </button>
            <a href="{{ agent is defined ? path('agent_show', {id: agent.id}) : path('agent_index') }}"
               class="text-gray-600 hover:text-gray-800 px-3 py-2 text-sm">
                Cancel
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
