{% extends 'base.html.twig' %}

{% block title %}{{ agent.name }} — Watchdog{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-6">
    <a href="{{ path('agent_index') }}" class="text-gray-500 hover:text-gray-700 text-sm">← Agents</a>
    <h1 class="text-2xl font-bold text-gray-800">{{ agent.name }}</h1>
    {% if agent.isOnline() %}
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded text-sm bg-green-100 text-green-700">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            Online
        </span>
    {% elseif agent.lastSeenAt is not null %}
        <span class="px-2.5 py-1 rounded text-sm bg-yellow-100 text-yellow-700">Offline</span>
    {% else %}
        <span class="px-2.5 py-1 rounded text-sm bg-gray-100 text-gray-500">Never seen</span>
    {% endif %}
</div>

{# One-time token display — shown immediately after registration or token regeneration #}
{% set rawToken = app.flashes('agent_token') %}
{% if rawToken|length > 0 %}
    <div class="mb-6 bg-amber-50 border border-amber-300 rounded-lg p-4">
        <p class="text-sm font-semibold text-amber-800 mb-1">Agent Token — copy it now, it won't be shown again!</p>
        <div class="flex items-center gap-2 mt-2">
            <code id="agent-token-value" class="flex-1 bg-white border border-amber-200 rounded px-3 py-2 text-sm font-mono text-amber-900 break-all select-all">{{ rawToken[0] }}</code>
            <button type="button" id="copy-token-btn"
                    class="px-3 py-2 bg-amber-600 text-white text-sm rounded hover:bg-amber-700 whitespace-nowrap cursor-pointer">
                Copy
            </button>
        </div>
        <p class="text-xs text-amber-600 mt-2">
            Set this as <code>WATCHDOG_AGENT_TOKEN</code> in the agent's environment. The token hash is stored — the raw value is gone after you leave this page.
        </p>
    </div>
    <script>
    (function () {
        const btn = document.getElementById('copy-token-btn');
        const val = document.getElementById('agent-token-value');
        if (!btn || !val) return;
        btn.addEventListener('click', () => {
            navigator.clipboard.writeText(val.textContent.trim()).then(() => {
                btn.textContent = 'Copied!';
                btn.classList.replace('bg-amber-600', 'bg-green-600');
                btn.classList.replace('hover:bg-amber-700', 'hover:bg-green-700');
                setTimeout(() => {
                    btn.textContent = 'Copy';
                    btn.classList.replace('bg-green-600', 'bg-amber-600');
                    btn.classList.replace('hover:bg-green-700', 'hover:bg-amber-700');
                }, 2000);
            });
        });
    }());
    </script>
{% endif %}

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    {# Info card #}
    <div class="md:col-span-1 bg-white rounded-lg shadow p-5 space-y-4 text-sm">
        <h2 class="font-semibold text-gray-700">Agent Info</h2>
        <dl class="space-y-2">
            <div class="flex justify-between">
                <dt class="text-gray-500">ID</dt>
                <dd class="font-mono text-gray-800">{{ agent.id }}</dd>
            </div>
            <div class="flex justify-between">
                <dt class="text-gray-500">Name</dt>
                <dd class="text-gray-800">{{ agent.name }}</dd>
            </div>
            <div class="flex justify-between">
                <dt class="text-gray-500">Registered</dt>
                <dd class="text-gray-800">{{ agent.createdAt|date('Y-m-d H:i') }}</dd>
            </div>
            <div class="flex justify-between">
                <dt class="text-gray-500">Last seen</dt>
                <dd class="text-gray-800">{{ agent.lastSeenAt ? agent.lastSeenAt|date('Y-m-d H:i') : '—' }}</dd>
            </div>
            <div class="flex justify-between">
                <dt class="text-gray-500">Checks assigned</dt>
                <dd class="text-gray-800">{{ agent.checks|length }}</dd>
            </div>
        </dl>

        <div class="border-t pt-4 space-y-2">
            <a href="{{ path('agent_edit', {id: agent.id}) }}"
               class="block w-full text-center border border-blue-300 text-blue-700 px-3 py-1.5 rounded text-sm hover:bg-blue-50">
                Edit Name
            </a>

            <form action="{{ path('agent_regenerate_token', {id: agent.id}) }}" method="post"
                  data-confirm-message="Regenerate token for &quot;{{ agent.name|e('html') }}&quot;? The current token will stop working immediately.">
                <input type="hidden" name="_token" value="{{ csrf_token('regenerate-token-' ~ agent.id) }}">
                <button type="submit"
                        class="w-full border border-yellow-300 text-yellow-700 px-3 py-1.5 rounded text-sm hover:bg-yellow-50 cursor-pointer">
                    Regenerate Token
                </button>
            </form>

            <form action="{{ path('agent_delete', {id: agent.id}) }}" method="post"
                  data-confirm-message="Delete agent &quot;{{ agent.name|e('html') }}&quot;? All associated checks will be unlinked.">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-agent-' ~ agent.id) }}">
                <button type="submit"
                        class="w-full border border-red-300 text-red-700 px-3 py-1.5 rounded text-sm hover:bg-red-50 cursor-pointer">
                    Delete Agent
                </button>
            </form>
        </div>
    </div>

    {# Assigned checks #}
    <div class="md:col-span-2 bg-white rounded-lg shadow overflow-hidden">
        <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-semibold text-gray-700 text-sm">Assigned Checks</h2>
        </div>
        {% if agent.checks is empty %}
            <div class="px-5 py-8 text-center text-gray-400 text-sm">
                No checks assigned to this agent yet.<br>
                Assign checks via <strong>Clients → Check → Edit</strong> and set the runner to "Agent".
            </div>
        {% else %}
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                    <tr>
                        <th class="px-4 py-3 text-left">Check</th>
                        <th class="px-4 py-3 text-left">Type</th>
                        <th class="px-4 py-3 text-center">Status</th>
                        <th class="px-4 py-3 text-right">Client</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for check in agent.checks %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-medium">
                            <a href="{{ path('check_edit', {clientId: check.client.id, id: check.id}) }}" class="text-blue-600 hover:underline">
                                {{ check.type }}
                            </a>
                        </td>
                        <td class="px-4 py-3 text-gray-500">{{ check.type }}</td>
                        <td class="px-4 py-3 text-center">
                            <span class="px-2 py-0.5 rounded text-xs {% if check.isActive %}bg-green-100 text-green-700{% else %}bg-gray-100 text-gray-500{% endif %}">
                                {{ check.isActive ? 'Active' : 'Inactive' }}
                            </span>
                        </td>
                        <td class="px-4 py-3 text-right text-gray-500">
                            <a href="{{ path('client_show', {id: check.client.id}) }}" class="hover:text-blue-600">
                                {{ check.client.name }}
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

</div>
{% endblock %}
