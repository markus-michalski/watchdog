{% extends 'base.html.twig' %}

{% block title %}{{ site.name }} — Watchdog{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <a href="{{ path('site_index') }}" class="text-gray-500 hover:text-gray-700 text-sm">← Sites</a>
        <h1 class="text-2xl font-bold text-gray-800">{{ site.name }}</h1>
        <span class="px-2 py-0.5 rounded text-xs {% if site.isActive %}bg-green-100 text-green-700{% else %}bg-gray-100 text-gray-500{% endif %}">
            {{ site.isActive ? 'Active' : 'Inactive' }}
        </span>
    </div>
    <a href="{{ path('site_edit', {id: site.id}) }}" class="border border-blue-300 text-blue-700 px-3 py-1.5 rounded text-sm hover:bg-blue-50">Edit site</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    {# Site info #}
    <div class="bg-white rounded-lg shadow p-5 lg:col-span-2">
        <h2 class="font-semibold text-gray-700 mb-3">Site details</h2>
        <dl class="text-sm space-y-2">
            <div class="flex gap-2">
                <dt class="text-gray-500 w-32 shrink-0">URL</dt>
                <dd><a href="{{ site.url }}" target="_blank" rel="noopener" class="text-blue-600 hover:underline">{{ site.url }}</a></dd>
            </div>
            {% if site.hasBasicAuth() %}
            <div class="flex gap-2">
                <dt class="text-gray-500 w-32 shrink-0">BasicAuth</dt>
                <dd class="text-yellow-700">{{ site.basicAuthUser }} / ••••••</dd>
            </div>
            {% endif %}
        </dl>
    </div>

    {# Contacts #}
    <div class="bg-white rounded-lg shadow p-5">
        <h2 class="font-semibold text-gray-700 mb-3">Alert contacts</h2>
        {% if site.contacts is empty %}
            <p class="text-sm text-gray-400 italic">No contacts — alerts are silent.</p>
        {% else %}
            <ul class="text-sm space-y-1">
                {% for contact in site.contacts %}
                    <li class="flex justify-between">
                        <span>{{ contact.name }}</span>
                        <span class="text-gray-500">{{ contact.email }}</span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
        <a href="{{ path('contact_new', {siteId: site.id}) }}" class="text-blue-600 hover:underline text-xs mt-3 inline-block">
            + Add contact
        </a>
    </div>
</div>

{# Checks #}
<div class="mt-6">
    <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold text-gray-800">
            Checks
            <span class="text-sm font-normal text-gray-400 ml-1">({{ site.checks|length }})</span>
        </h2>
        <div class="flex items-center gap-3">
            {% if site.checks|length > 4 %}
            <input
                type="search"
                id="check-filter"
                placeholder="Filter checks…"
                class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 w-48"
                oninput="filterChecks(this.value)"
            >
            {% endif %}
            <a href="{{ path('check_new', {siteId: site.id}) }}" class="bg-blue-600 text-white px-3 py-1.5 rounded hover:bg-blue-700 text-sm">
                + Add check
            </a>
        </div>
    </div>

    {% if site.checks is empty %}
        <div class="bg-white rounded-lg shadow p-6 text-center text-gray-500 text-sm">
            No checks configured. Add your first check above.
        </div>
    {% else %}
        <div class="grid gap-3" id="check-list">
            {% for check in site.checks %}
                {% set result = latestResults[check.id] ?? null %}
                <div class="bg-white rounded-lg shadow p-4 flex items-center gap-4 check-row" data-label="{{ check.label|lower }}">
                    <div class="flex-1 min-w-0">
                        <p class="font-medium text-gray-800">{{ check.label }}</p>
                        {% if check.config is not empty %}
                            <p class="text-xs text-gray-400 mt-0.5 font-mono truncate">{{ check.config|json_encode }}</p>
                        {% endif %}
                    </div>

                    {# Health status from last result #}
                    <div class="flex items-center gap-2 shrink-0">
                        {% if result %}
                            <span class="px-2 py-0.5 rounded text-xs font-semibold {{ result.status.cssClass() }}">
                                {{ result.status.label() }}
                            </span>
                            {% if result.message %}
                                <span class="text-xs text-gray-500 hidden sm:block max-w-xs truncate" title="{{ result.message }}">{{ result.message }}</span>
                            {% endif %}
                            <span class="text-xs text-gray-400 hidden sm:block">{{ result.checkedAt|date('d.m. H:i') }}</span>
                            {% if result.responseTimeMs %}
                                <span class="text-xs text-gray-400 hidden md:block">{{ result.responseTimeMs }}ms</span>
                            {% endif %}
                        {% else %}
                            <span class="px-2 py-0.5 rounded text-xs font-semibold text-gray-500 bg-gray-100">PENDING</span>
                        {% endif %}
                    </div>

                    {# Only show Disabled badge — Active is the default, no need to label it #}
                    {% if not check.isActive %}
                        <span class="text-xs bg-gray-100 text-gray-400 px-2 py-0.5 rounded shrink-0">Disabled</span>
                    {% endif %}

                    {# Action buttons #}
                    <div class="flex items-center gap-1.5 shrink-0">
                        <a href="{{ path('check_history', {siteId: site.id, checkId: check.id}) }}"
                           class="border border-gray-300 text-gray-600 px-2.5 py-1 rounded text-xs hover:bg-gray-50 whitespace-nowrap">
                            History
                        </a>
                        <a href="{{ path('check_edit', {siteId: site.id, checkId: check.id}) }}"
                           class="border border-blue-300 text-blue-700 px-2.5 py-1 rounded text-xs hover:bg-blue-50">
                            Edit
                        </a>
                        <form action="{{ path('check_run', {siteId: site.id, checkId: check.id}) }}" method="post" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('run_check' ~ check.id) }}">
                            <button type="submit"
                                    class="border border-green-300 text-green-700 px-2.5 py-1 rounded text-xs hover:bg-green-50 cursor-pointer">
                                Run now
                            </button>
                        </form>
                        <form action="{{ path('check_delete', {siteId: site.id, checkId: check.id}) }}" method="post" class="inline"
                              onsubmit="return confirm('Delete this check?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_check' ~ check.id) }}">
                            <button type="submit"
                                    class="border border-red-300 text-red-700 px-2.5 py-1 rounded text-xs hover:bg-red-50 cursor-pointer">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>

        <p id="check-empty" class="hidden text-center text-gray-400 text-sm mt-4">No checks match your filter.</p>
    {% endif %}
</div>

<script>
function filterChecks(query) {
    const rows = document.querySelectorAll('.check-row');
    const empty = document.getElementById('check-empty');
    const q = query.toLowerCase().trim();
    let visible = 0;
    rows.forEach(row => {
        const match = !q || row.dataset.label.includes(q) || row.textContent.toLowerCase().includes(q);
        row.style.display = match ? '' : 'none';
        if (match) visible++;
    });
    empty.classList.toggle('hidden', visible > 0);
}
</script>
{% endblock %}
