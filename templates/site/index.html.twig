{% extends 'base.html.twig' %}

{% block title %}Sites — Watchdog{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Sites</h1>
    <a href="{{ path('site_new') }}" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm">
        + Add Site
    </a>
</div>

{% if sites is empty %}
    <div class="bg-white rounded-lg shadow p-8 text-center text-gray-500">
        No sites configured yet.
    </div>
{% else %}
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                <tr>
                    <th class="px-4 py-3 text-left">Name</th>
                    <th class="px-4 py-3 text-left">URL</th>
                    <th class="px-4 py-3 text-center">Checks</th>
                    <th class="px-4 py-3 text-center">Status</th>
                    <th class="px-4 py-3 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for site in sites %}
                <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3 font-medium">
                        <a href="{{ path('site_show', {id: site.id}) }}" class="text-blue-600 hover:underline">
                            {{ site.name }}
                        </a>
                    </td>
                    <td class="px-4 py-3 text-gray-600 truncate max-w-xs">{{ site.url }}</td>
                    <td class="px-4 py-3 text-center text-gray-600">{{ site.checks|length }}</td>
                    <td class="px-4 py-3 text-center">
                        <span class="px-2 py-0.5 rounded text-xs {% if site.isActive %}bg-green-100 text-green-700{% else %}bg-gray-100 text-gray-500{% endif %}">
                            {{ site.isActive ? 'Active' : 'Inactive' }}
                        </span>
                    </td>
                    <td class="px-4 py-3 text-right">
                        <div class="flex items-center justify-end gap-1.5">
                            <a href="{{ path('site_edit', {id: site.id}) }}"
                               class="border border-blue-300 text-blue-700 px-2.5 py-1 rounded text-xs hover:bg-blue-50">Edit</a>
                            <form action="{{ path('site_delete', {id: site.id}) }}" method="post" class="inline"
                                  onsubmit="return confirm('Delete {{ site.name|e('js') }}?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ site.id) }}">
                                <button type="submit"
                                        class="border border-red-300 text-red-700 px-2.5 py-1 rounded text-xs hover:bg-red-50 cursor-pointer">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
