{% extends 'base.html.twig' %}

{% block title %}{{ title }} — Watchdog{% endblock %}

{% block stylesheets %}
<style>
    .form-input { @apply w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500; }
    .form-label { @apply block text-sm font-medium text-gray-700 mb-1; }
</style>
{% endblock %}

{% block body %}
<div class="max-w-lg">
    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('client_show', {id: client.id}) }}" class="text-gray-500 hover:text-gray-700 text-sm">← {{ client.name }}</a>
        <h1 class="text-2xl font-bold text-gray-800">{{ title }}</h1>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        {{ form_start(form, {attr: {class: 'space-y-4'}}) }}

        <div>
            {{ form_label(form.url, null, {label_attr: {class: 'form-label'}}) }}
            {{ form_widget(form.url, {attr: {class: 'w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {{ form_errors(form.url) }}
        </div>

        <div>
            {{ form_label(form.label, null, {label_attr: {class: 'form-label'}}) }}
            {{ form_widget(form.label, {attr: {class: 'w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            {% if form.label.vars.help is defined and form.label.vars.help %}
                <p class="text-xs text-gray-400 mt-0.5">{{ form.label.vars.help }}</p>
            {% endif %}
            {{ form_errors(form.label) }}
        </div>

        <hr class="border-gray-200">
        <p class="text-sm font-medium text-gray-700">BasicAuth (optional)</p>

        <div class="grid grid-cols-2 gap-4">
            <div>
                {{ form_label(form.basicAuthUser, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.basicAuthUser, {attr: {class: 'w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            </div>
            <div>
                {{ form_label(form.basicAuthPassword, null, {label_attr: {class: 'form-label'}}) }}
                {{ form_widget(form.basicAuthPassword, {attr: {class: 'w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500'}}) }}
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-blue-600 text-white px-5 py-2 rounded hover:bg-blue-700 text-sm font-medium">
                Save
            </button>
            <a href="{{ path('client_show', {id: client.id}) }}" class="text-gray-600 hover:text-gray-800 px-3 py-2 text-sm">
                Cancel
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
