{% extends 'base.html.twig' %}

{% block title %}{{ client.name }} — Watchdog{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        <a href="{{ path('client_index') }}" class="text-gray-500 hover:text-gray-700 text-sm">← Clients</a>
        <h1 class="text-2xl font-bold text-gray-800">{{ client.name }}</h1>
        <span class="px-2 py-0.5 rounded text-xs {% if client.isActive %}bg-green-100 text-green-700{% else %}bg-gray-100 text-gray-500{% endif %}">
            {{ client.isActive ? 'Active' : 'Inactive' }}
        </span>
    </div>
    <a href="{{ path('client_edit', {id: client.id}) }}" class="border border-blue-300 text-blue-700 px-3 py-1.5 rounded text-sm hover:bg-blue-50">Edit client</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    {# URLs #}
    <div class="bg-white rounded-lg shadow p-5 lg:col-span-2">
        <div class="flex items-center justify-between mb-3">
            <h2 class="font-semibold text-gray-700">URLs</h2>
            <a href="{{ path('client_url_new', {id: client.id}) }}" class="text-xs bg-blue-600 text-white px-3 py-1.5 rounded hover:bg-blue-700">+ Add URL</a>
        </div>
        {% if client.urls is empty %}
            <p class="text-sm text-gray-400 italic">No URLs configured. Add one to create HTTP checks.</p>
        {% else %}
            <ul class="divide-y divide-gray-100">
                {% for url in client.urls|sort((a, b) => (a.label ?? a.url) <=> (b.label ?? b.url)) %}
                <li class="py-2 flex items-center justify-between gap-3">
                    <div class="min-w-0">
                        {% if url.label %}
                            <span class="font-medium text-gray-800 text-sm">{{ url.label }}</span>
                            <span class="text-gray-400 text-xs ml-2">{{ url.url }}</span>
                        {% else %}
                            <a href="{{ url.url }}" target="_blank" rel="noopener" class="text-blue-600 hover:underline text-sm truncate block">{{ url.url }}</a>
                        {% endif %}
                        {% if url.hasBasicAuth() %}
                            <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded ml-1">BasicAuth: {{ url.basicAuthUser }}</span>
                        {% endif %}
                    </div>
                    <div class="flex items-center gap-1.5 shrink-0">
                        <a href="{{ path('client_url_edit', {clientId: client.id, urlId: url.id}) }}"
                           class="border border-blue-300 text-blue-700 px-2 py-0.5 rounded text-xs hover:bg-blue-50">Edit</a>
                        <form action="{{ path('client_url_delete', {clientId: client.id, urlId: url.id}) }}" method="post" class="contents"
                              data-confirm-message="Delete this URL?">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_url' ~ url.id) }}">
                            <button type="submit" class="border border-red-300 text-red-700 px-2 py-0.5 rounded text-xs hover:bg-red-50 cursor-pointer">Delete</button>
                        </form>
                    </div>
                </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    {# Contacts #}
    <div class="bg-white rounded-lg shadow p-5 self-start">
        <div class="flex items-center justify-between mb-3">
            <h2 class="font-semibold text-gray-700">Alert contacts</h2>
            <a href="{{ path('contact_index') }}" class="text-xs text-blue-600 hover:underline">Manage</a>
        </div>
        {% if client.contacts is empty %}
            <p class="text-sm text-gray-400 italic">No contacts — alerts are silent.</p>
            <a href="{{ path('client_edit', {id: client.id}) }}" class="text-blue-600 hover:underline text-xs mt-2 inline-block">Assign contacts in client settings</a>
        {% else %}
            <ul class="text-sm space-y-1.5">
                {% for contact in client.contacts %}
                    <li>
                        <span class="font-medium text-gray-800">{{ contact.name }}</span>
                        <span class="text-gray-400 ml-1">{{ contact.email }}</span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</div>

{# Checks #}
<div class="mt-6">
    <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-semibold text-gray-800">
            Checks
            <span class="text-sm font-normal text-gray-400 ml-1">({{ client.checks|length }})</span>
        </h2>
        <a href="{{ path('check_new', {clientId: client.id}) }}" class="bg-blue-600 text-white px-3 py-1.5 rounded hover:bg-blue-700 text-sm">
            + Add check
        </a>
    </div>

    {% if client.checks is not empty %}
    <div class="flex flex-wrap items-center gap-2 mb-3">
        <input type="search" id="check-search" placeholder="Filter by label…"
               class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 w-48">

        {# Status multi-select dropdown #}
        <div class="relative" data-dd-wrap="status">
            <button type="button" data-dd-btn="status"
                    class="flex items-center gap-1.5 border border-gray-300 rounded px-3 py-1.5 text-xs font-medium bg-white text-gray-700 hover:bg-gray-50 select-none">
                <span data-dd-label="status">Status: All</span>
                <svg class="w-3 h-3 text-gray-400 shrink-0 transition-transform duration-150" data-dd-chevron="status"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div class="hidden absolute left-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-lg shadow-lg py-1 min-w-[170px]"
                 data-dd-panel="status">
                <label class="flex items-center gap-2.5 px-3 py-1.5 hover:bg-gray-50 cursor-pointer text-xs text-gray-700">
                    <input type="checkbox" value="ok" data-status-cb class="rounded border-gray-300 accent-blue-600 cursor-pointer">
                    <span class="w-2 h-2 rounded-full bg-green-400 shrink-0"></span> OK
                </label>
                <label class="flex items-center gap-2.5 px-3 py-1.5 hover:bg-gray-50 cursor-pointer text-xs text-gray-700">
                    <input type="checkbox" value="warn" data-status-cb class="rounded border-gray-300 accent-blue-600 cursor-pointer">
                    <span class="w-2 h-2 rounded-full bg-orange-400 shrink-0"></span> WARN
                </label>
                <label class="flex items-center gap-2.5 px-3 py-1.5 hover:bg-gray-50 cursor-pointer text-xs text-gray-700">
                    <input type="checkbox" value="fail" data-status-cb class="rounded border-gray-300 accent-blue-600 cursor-pointer">
                    <span class="w-2 h-2 rounded-full bg-red-400 shrink-0"></span> FAIL
                </label>
                <label class="flex items-center gap-2.5 px-3 py-1.5 hover:bg-gray-50 cursor-pointer text-xs text-gray-700">
                    <input type="checkbox" value="unknown" data-status-cb class="rounded border-gray-300 accent-blue-600 cursor-pointer">
                    <span class="w-2 h-2 rounded-full bg-yellow-400 shrink-0"></span> UNKNOWN
                </label>
                <label class="flex items-center gap-2.5 px-3 py-1.5 hover:bg-gray-50 cursor-pointer text-xs text-gray-700">
                    <input type="checkbox" value="pending" data-status-cb class="rounded border-gray-300 accent-blue-600 cursor-pointer">
                    <span class="w-2 h-2 rounded-full bg-gray-300 shrink-0"></span> PENDING
                </label>
                <div class="border-t border-gray-100 mt-1 pt-1 px-3 pb-1">
                    <button type="button" data-dd-clear="status" class="text-xs text-gray-400 hover:text-gray-600">Clear</button>
                </div>
            </div>
        </div>

        {# Type multi-select dropdown — only when more than 1 type present #}
        {% if typeLabels is defined and typeLabels|length > 1 %}
        <div class="relative" data-dd-wrap="type">
            <button type="button" data-dd-btn="type"
                    class="flex items-center gap-1.5 border border-gray-300 rounded px-3 py-1.5 text-xs font-medium bg-white text-gray-700 hover:bg-gray-50 select-none">
                <span data-dd-label="type">Type: All</span>
                <svg class="w-3 h-3 text-gray-400 shrink-0 transition-transform duration-150" data-dd-chevron="type"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
            </button>
            <div class="hidden absolute left-0 top-full mt-1 z-20 bg-white border border-gray-200 rounded-lg shadow-lg py-1 min-w-[180px]"
                 data-dd-panel="type">
                {% for type, label in typeLabels %}
                <label class="flex items-center gap-2.5 px-3 py-1.5 hover:bg-gray-50 cursor-pointer text-xs text-gray-700">
                    <input type="checkbox" value="{{ type }}" data-type-cb class="rounded border-gray-300 accent-blue-600 cursor-pointer">
                    {{ label }}
                </label>
                {% endfor %}
                <div class="border-t border-gray-100 mt-1 pt-1 px-3 pb-1">
                    <button type="button" data-dd-clear="type" class="text-xs text-gray-400 hover:text-gray-600">Clear</button>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
    {% endif %}

    {% if client.checks is empty %}
        <div class="bg-white rounded-lg shadow p-6 text-center text-gray-500 text-sm">
            No checks configured. Add your first check above.
        </div>
    {% else %}
        <div class="grid gap-3" id="check-list">
            {% for check in client.checks|sort((a, b) => a.label <=> b.label) %}
                {% set result = latestResults[check.id] ?? null %}
                {% set _searchText = check.label|lower %}
                {% set _target = checkTargets[check.id] ?? null %}
                {% if _target is not null %}
                    {% set _searchText = _searchText ~ ' ' ~ _target|lower %}
                {% endif %}
                <div class="bg-white rounded-lg shadow p-4 flex items-center gap-4 check-row"
                     data-label="{{ _searchText }}"
                     data-status="{{ result ? result.status.value : 'pending' }}"
                     data-type="{{ check.type }}">
                    <div class="flex-1 min-w-0">
                        <p class="font-medium text-gray-800 flex items-center gap-2 flex-wrap">
                            {{ check.label }}
                            {% if _target is not null %}
                                <span class="text-xs font-normal text-gray-500 bg-gray-50 border border-gray-200 rounded px-2 py-0.5 font-mono">{{ _target }}</span>
                            {% endif %}
                        </p>
                        <p class="text-xs text-gray-400 mt-0.5">
                            {% if check.runAtTime %}daily at {{ check.runAtTime }}{% else %}every {{ check.checkIntervalMinutes|duration }}{% endif %}
                        </p>
                    </div>

                    <div class="flex items-center gap-2 shrink-0">
                        {% if result %}
                            <span class="px-2 py-0.5 rounded text-xs font-semibold {{ result.status.cssClass() }}">
                                {{ result.status.label() }}
                            </span>
                            {% if result.message %}
                                <span class="text-xs font-semibold hidden sm:block {{ result.status.textClass() }}">{{ result.message|format_durations }}</span>
                            {% endif %}
                            <span class="text-xs text-gray-400 hidden sm:block">{{ result.checkedAt|date('d.m. H:i') }}</span>
                            {% if result.responseTimeMs %}
                                <span class="text-xs text-gray-400 hidden md:block">{{ result.responseTimeMs }}ms</span>
                            {% endif %}
                        {% else %}
                            <span class="px-2 py-0.5 rounded text-xs font-semibold text-gray-500 bg-gray-100">PENDING</span>
                        {% endif %}
                    </div>

                    {% if not check.isActive %}
                        <span class="text-xs bg-gray-100 text-gray-400 px-2 py-0.5 rounded shrink-0">Disabled</span>
                    {% endif %}

                    <div class="flex items-center gap-1.5 shrink-0">
                        <a href="{{ path('check_history', {clientId: client.id, checkId: check.id}) }}"
                           class="border border-gray-300 text-gray-600 px-2.5 py-1 rounded text-xs hover:bg-gray-50 whitespace-nowrap">
                            History
                        </a>
                        <a href="{{ path('check_edit', {clientId: client.id, checkId: check.id}) }}"
                           class="border border-blue-300 text-blue-700 px-2.5 py-1 rounded text-xs hover:bg-blue-50">
                            Edit
                        </a>
                        <form action="{{ path('check_run', {clientId: client.id, checkId: check.id}) }}" method="post" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('run_check' ~ check.id) }}">
                            <button type="submit"
                                    class="border border-green-300 text-green-700 px-2.5 py-1 rounded text-xs hover:bg-green-50 cursor-pointer">
                                Run now
                            </button>
                        </form>
                        <form action="{{ path('check_delete', {clientId: client.id, checkId: check.id}) }}" method="post" class="contents"
                              data-confirm-message="Delete this check?">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_check' ~ check.id) }}">
                            <button type="submit"
                                    class="border border-red-300 text-red-700 px-2.5 py-1 rounded text-xs hover:bg-red-50 cursor-pointer">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>

        <p id="check-empty" class="hidden text-center text-gray-400 text-sm mt-4">No checks match your filter.</p>
    {% endif %}
</div>

<script>
(function () {
    const rows   = document.querySelectorAll('.check-row');
    const empty  = document.getElementById('check-empty');
    const search = document.getElementById('check-search');

    const activeStatuses = new Set();
    const activeTypes    = new Set();

    function applyFilters() {
        const q = search ? search.value.toLowerCase().trim() : '';
        let visible = 0;
        rows.forEach(row => {
            const statusMatch = activeStatuses.size === 0 || activeStatuses.has(row.dataset.status);
            const typeMatch   = activeTypes.size === 0    || activeTypes.has(row.dataset.type);
            const labelMatch  = !q || row.dataset.label.includes(q);
            const show = statusMatch && typeMatch && labelMatch;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        if (empty) empty.classList.toggle('hidden', visible > 0);
    }

    if (search) search.addEventListener('input', applyFilters);

    function buildDropdown(key, cbAttr, activeSet, prefix, nameFn) {
        const btn      = document.querySelector(`[data-dd-btn="${key}"]`);
        const panel    = document.querySelector(`[data-dd-panel="${key}"]`);
        const labelEl  = document.querySelector(`[data-dd-label="${key}"]`);
        const chevron  = document.querySelector(`[data-dd-chevron="${key}"]`);
        const cbs      = document.querySelectorAll(`[${cbAttr}]`);
        const clearBtn = document.querySelector(`[data-dd-clear="${key}"]`);
        if (!btn) return;

        function updateLabel() {
            const isFiltered = activeSet.size > 0;
            btn.classList.toggle('border-blue-400', isFiltered);
            btn.classList.toggle('text-blue-700',   isFiltered);
            btn.classList.toggle('border-gray-300', !isFiltered);
            btn.classList.toggle('text-gray-700',   !isFiltered);
            if (activeSet.size === 0)      labelEl.textContent = `${prefix}: All`;
            else if (activeSet.size === 1) labelEl.textContent = `${prefix}: ${nameFn([...activeSet][0])}`;
            else                           labelEl.textContent = `${prefix}: ${activeSet.size} selected`;
        }

        function openPanel() {
            document.querySelectorAll('[data-dd-panel]').forEach(p => {
                if (p === panel) return;
                p.classList.add('hidden');
                const c = document.querySelector(`[data-dd-chevron="${p.dataset.ddPanel}"]`);
                if (c) c.style.transform = '';
            });
            panel.classList.remove('hidden');
            chevron.style.transform = 'rotate(180deg)';
        }

        function closePanel() {
            panel.classList.add('hidden');
            chevron.style.transform = '';
        }

        btn.addEventListener('click', e => {
            e.stopPropagation();
            panel.classList.contains('hidden') ? openPanel() : closePanel();
        });

        cbs.forEach(cb => cb.addEventListener('change', () => {
            cb.checked ? activeSet.add(cb.value) : activeSet.delete(cb.value);
            updateLabel();
            applyFilters();
        }));

        if (clearBtn) clearBtn.addEventListener('click', () => {
            activeSet.clear();
            cbs.forEach(cb => cb.checked = false);
            updateLabel();
            applyFilters();
        });
    }

    const STATUS_NAMES = { ok: 'OK', warn: 'WARN', fail: 'FAIL', unknown: 'UNKNOWN', pending: 'PENDING' };

    function typeName(val) {
        const cb = document.querySelector(`[data-type-cb][value="${val}"]`);
        return cb ? cb.closest('label').textContent.trim() : val;
    }

    buildDropdown('status', 'data-status-cb', activeStatuses, 'Status', v => STATUS_NAMES[v] ?? v);
    buildDropdown('type',   'data-type-cb',   activeTypes,    'Type',   typeName);

    document.addEventListener('click', () => {
        document.querySelectorAll('[data-dd-panel]').forEach(p => p.classList.add('hidden'));
        document.querySelectorAll('[data-dd-chevron]').forEach(c => c.style.transform = '');
    });

    document.addEventListener('keydown', e => {
        if (e.key !== 'Escape') return;
        document.querySelectorAll('[data-dd-panel]').forEach(p => p.classList.add('hidden'));
        document.querySelectorAll('[data-dd-chevron]').forEach(c => c.style.transform = '');
    });
})();
</script>
{% endblock %}
