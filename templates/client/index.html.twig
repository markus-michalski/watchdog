{% extends 'base.html.twig' %}

{% block title %}Clients — Watchdog{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-bold text-gray-800">Clients</h1>
    <a href="{{ path('client_new') }}" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm">
        + Add Client
    </a>
</div>

{% if clients is empty %}
    <div class="bg-white rounded-lg shadow p-8 text-center text-gray-500">
        No clients configured yet.
    </div>
{% else %}
    <div class="flex flex-wrap items-center gap-3 mb-4">
        <input type="search" id="client-search" placeholder="Filter by name…"
               class="border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-300 w-52">
        <div class="flex gap-1.5">
            <button data-active-filter="all"   class="client-filter-btn active px-3 py-1.5 rounded text-xs font-medium border border-gray-300 bg-gray-100 text-gray-700">All</button>
            <button data-active-filter="1"     class="client-filter-btn px-3 py-1.5 rounded text-xs font-medium border border-green-200 text-green-700 hover:bg-green-50">Active</button>
            <button data-active-filter="0"     class="client-filter-btn px-3 py-1.5 rounded text-xs font-medium border border-gray-200 text-gray-500 hover:bg-gray-50">Inactive</button>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
                <tr>
                    <th class="px-4 py-3 text-left">Name</th>
                    <th class="px-4 py-3 text-center">URLs</th>
                    <th class="px-4 py-3 text-center">Checks</th>
                    <th class="px-4 py-3 text-center">Status</th>
                    <th class="px-4 py-3 text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100" id="clients-tbody">
                {% for client in clients %}
                <tr class="hover:bg-gray-50"
                    data-name="{{ client.name|lower }}"
                    data-active="{{ client.isActive ? '1' : '0' }}">
                    <td class="px-4 py-3 font-medium">
                        <a href="{{ path('client_show', {id: client.id}) }}" class="text-blue-600 hover:underline">
                            {{ client.name }}
                        </a>
                    </td>
                    <td class="px-4 py-3 text-center text-gray-600">{{ client.urls|length }}</td>
                    <td class="px-4 py-3 text-center text-gray-600">{{ client.checks|length }}</td>
                    <td class="px-4 py-3 text-center">
                        <span class="px-2 py-0.5 rounded text-xs {% if client.isActive %}bg-green-100 text-green-700{% else %}bg-gray-100 text-gray-500{% endif %}">
                            {{ client.isActive ? 'Active' : 'Inactive' }}
                        </span>
                    </td>
                    <td class="px-4 py-3 text-right">
                        <div class="flex items-center justify-end gap-1.5">
                            <a href="{{ path('client_edit', {id: client.id}) }}"
                               class="border border-blue-300 text-blue-700 px-2.5 py-1 rounded text-xs hover:bg-blue-50">Edit</a>
                            <form action="{{ path('client_delete', {id: client.id}) }}" method="post" class="contents"
                                  data-confirm-message="Delete {{ client.name|e('html') }}?">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
                                <button type="submit"
                                        class="border border-red-300 text-red-700 px-2.5 py-1 rounded text-xs hover:bg-red-50 cursor-pointer">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
                <tr id="clients-empty-row" class="hidden">
                    <td colspan="5" class="px-4 py-6 text-center text-gray-400 text-sm">No clients match your filter.</td>
                </tr>
            </tbody>
        </table>
    </div>
{% endif %}

<script>
(function () {
    const rows = document.querySelectorAll('#clients-tbody tr[data-name]');
    const search = document.getElementById('client-search');
    const btns = document.querySelectorAll('[data-active-filter]');
    const emptyRow = document.getElementById('clients-empty-row');
    let activeFilter = 'all';

    function applyFilters() {
        const q = search ? search.value.toLowerCase().trim() : '';
        let visible = 0;
        rows.forEach(row => {
            const nameMatch = !q || row.dataset.name.includes(q);
            const activeMatch = activeFilter === 'all' || row.dataset.active === activeFilter;
            const show = nameMatch && activeMatch;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        if (emptyRow) emptyRow.classList.toggle('hidden', visible > 0);
    }

    if (search) search.addEventListener('input', applyFilters);

    btns.forEach(btn => {
        btn.addEventListener('click', () => {
            activeFilter = btn.dataset.activeFilter;
            btns.forEach(b => b.classList.remove('bg-gray-100', 'bg-green-100'));
            btn.classList.add(activeFilter === '1' ? 'bg-green-100' : 'bg-gray-100');
            applyFilters();
        });
    });
})();
</script>
{% endblock %}
