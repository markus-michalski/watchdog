# Stage environment — copy to .env.stage and fill in values
# cp .env.stage.example .env.stage

APP_ENV=prod
APP_DEBUG=1
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=

DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

APP_ADMIN_USER=admin
# Generate: docker compose -f compose.stage.yml exec app php bin/console security:hash-password
APP_ADMIN_PASSWORD_HASH=

# Base URL for links in alert emails
DEFAULT_URI=https://stage.example.com

# Agent token — register via Dashboard UI (Agents → Register Agent), copy the one-time raw token
WATCHDOG_AGENT_TOKEN=

# Mailpit on stage (port defined in compose.stage.yml)
MAILER_DSN=smtp://mailpit:1025
MAILER_FROM=watchdog@example.com
