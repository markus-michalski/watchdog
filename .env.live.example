# Live environment — copy to .env.live and fill in values
# cp .env.live.example .env.live

APP_ENV=prod
APP_DEBUG=0
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=

DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

APP_ADMIN_USER=admin
# Generate: docker compose -f docker-compose.prod.yml exec app php bin/console security:hash-password
APP_ADMIN_PASSWORD_HASH=

# Base URL for links in alert emails
DEFAULT_URI=https://your-domain.com

# Agent token — register via Dashboard UI (Agents → Register Agent), copy the one-time raw token
WATCHDOG_AGENT_TOKEN=

# Real SMTP for live
MAILER_DSN=smtp://user:pass@smtp.example.com:587
MAILER_FROM=watchdog@your-domain.com
